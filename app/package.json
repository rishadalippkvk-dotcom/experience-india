{
    "name": "my-project-monorepo",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev:client": "npm run dev -w apps/client",
        "dev:server": "npm run dev -w apps/server",
        "seed": "npm run seed -w apps/server",
        "build": "npm run build --workspaces",
        "start": "npm run start --workspaces"
    }
}